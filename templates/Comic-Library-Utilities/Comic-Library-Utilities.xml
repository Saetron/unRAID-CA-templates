<?xml version="1.0"?>
<Container version="2">
  <Name>Comic-Library-Utilities</Name>
  <Repository>allaboutduncan/comic-utils-web:latest</Repository>
  <Registry>https://hub.docker.com/r/allaboutduncan/comic-utils-web</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/197096-support-saetron-docker-templates/</Support>
  <Project>https://github.com/allaboutduncan/clu-comics</Project>
  <Overview>Comic Library Utilities is a tool to manage large comic libraries. You can convert, rename, move, enhance CBZ files within the app. And add metdata to your files from various sources.</Overview>
  <Category>MediaApp:Books MediaServer:Books</Category>
  <WebUI>http://[IP]:[PORT:5577]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Saetron/unRAID-CA-templates/refs/heads/main/templates/Comic-Library-Utilities/Comic-Library-Utilities.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/allaboutduncan/clu-comics/refs/heads/main/images/clu-logo-360.png</Icon>
  <Config Name="WebUI" Target="5577" Default="5577" Mode="tcp" Description="" Type="Port" Display="always" Required="false" Mask="false">5577</Config>
  <Config Name="Main Library" Target="/data" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/media/</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="" Type="Variable" Display="advanced" Required="true" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="" Type="Variable" Display="advanced" Required="true" Mask="false">100</Config>
  <Config Name="UMASK" Target="UMASK" Default="022" Mode="" Description="" Type="Variable" Display="advanced" Required="true" Mask="false">022</Config>
  <Config Name="Config" Target="/config" Default="" Mode="rw" Description="" Type="Path" Display="advanced" Required="true" Mask="false">/mnt/user/appdata/clu/config</Config>
  <Config Name="Cache" Target="/cache" Default="" Mode="rw" Description="" Type="Path" Display="advanced" Required="true" Mask="false">/mnt/user/appdata/clu/cache</Config>
</Container>