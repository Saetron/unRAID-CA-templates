<?xml version="1.0"?>
<Container version="2">
  <Name>Shimmie2</Name>
  <Repository>shish2k/shimmie2:latest</Repository>
  <Registry>https://hub.docker.com/r/shish2k/shimmie2</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/topic/197096-support-saetron-docker-templates/</Support>
  <Project>https://github.com/shish/shimmie2</Project>
  <Overview>Shimmie2 is a lightweight, tag-based image gallery engine. It features a robust extension system, advanced metadata tagging, and a community-focused "Booru" style interface for organizing large image collections. &#13;
&#13;
This template uses an integrated SQLite database for easy setup</Overview>
  <Category>MediaApp:Photos</Category>
  <WebUI>http://[IP]:[PORT:8000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Saetron/unRAID-CA-templates/refs/heads/main/templates/shimmie2/shimmie2.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/shish/shimmie2/refs/heads/main/ext/static_files/static/favicon_64.png</Icon>
  <Config Name="Config" Target="/app/data" Default="/mnt/user/appdata/shimmie2" Mode="rw" Description="Core application data and SQLite database." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/shimmie2</Config>
  <Config Name="WebUI" Target="8000" Default="8000" Mode="tcp" Description="Web interface port." Type="Port" Display="always" Required="true" Mask="false">8000</Config>
</Container>